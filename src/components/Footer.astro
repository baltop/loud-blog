---
const today = new Date();
---

<footer>
	<hr />
	<p>&copy; {today.getFullYear()} 나의 블로그</p>
</footer>
<style>
	footer {
		max-width: 720px;
		margin: 0 auto;
		padding: 0 1.5em 3em 1.5em;
		text-align: center;
		color: var(--text-faint);
		font-size: 0.85em;
	}
	footer hr {
		margin: 0 0 1.5em 0;
	}
	footer p {
		margin: 0;
	}
</style>
